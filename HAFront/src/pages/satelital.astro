---
    import Layout from "../layouts/LayoutVariable.astro";
    ---

    <Layout title="Huella de Altura | Interfaz de Auditoría Satelital">

    <section class="flex overflow-hidden -m-8" style="height: calc(100vh - 4rem);">

        <div class="flex-grow relative bg-surface-dim overflow-hidden">

        <div class="absolute inset-0 z-0">
            <img
            alt="Mapa Satelital"
            class="w-full h-full object-cover grayscale-[0.2] contrast-[1.1]"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDjAtsFX3vINrNQMtsTCQyAm5BcIy-r1CDh39eHkSCO-lPkbrpW3lKJXRxrSlzw1Aie7kt1beOXOiRSgmcd2lCRNeNNrO2c9HRB5sShshVsCfKPBWwHQnW-QGU_5ot0cv51KkIfCHH1qUOOc53PO8wApcFvki8fKTibBgusGFdLG_Y7O6IO9LH_yOKFjUIsP8rTIi9KfUNRqli0AgHXOnplAi_wvT39b3gvY9I1AhP7jMudm3Oxa_Dchg4wHq7Y0wHNeXC9kwAoi9M"
            />
            <div class="absolute inset-0 map-gradient-overlay"></div>
        </div>

        <div class="scanning-line"></div>

        <div class="absolute top-4 left-4 z-30 flex flex-col gap-3">

            <div class="glass-panel border border-outline-variant rounded-xl p-4 shadow-sm w-64">
            <div class="flex justify-between items-start mb-1">
                <span class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold">Índice Satelital</span>
                <span class="px-2 py-0.5 bg-primary-container text-on-primary-container rounded text-[10px] font-bold">EN VIVO</span>
            </div>
            <div class="text-xl font-semibold text-primary mt-1">Sentinel-2B</div>
            <div class="mt-2 flex flex-col gap-1">
                <div class="flex justify-between text-xs">
                <span class="text-on-surface-variant">Banda Espectral</span>
                <span class="font-mono">B8A (Borde Rojo)</span>
                </div>
                <div class="flex justify-between text-xs">
                <span class="text-on-surface-variant">Cobertura Nubosa</span>
                <span class="font-mono text-green-600">0.4%</span>
                </div>
            </div>
            </div>

            <div class="glass-panel border border-outline-variant rounded-xl p-4 shadow-sm w-64">
            <span class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold">Coordenadas y Fecha</span>
            <div class="mt-2 space-y-2">
                <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-secondary">location_on</span>
                <span class="text-sm font-mono">0°13'07"S 78°30'35"W</span>
                </div>
                <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-secondary">calendar_today</span>
                <span class="text-sm font-mono">24 OCT, 2023</span>
                </div>
            </div>
            </div>
        </div>

        <div class="absolute bottom-4 right-4 z-30 flex flex-col gap-2">
            <button class="w-10 h-10 glass-panel border border-outline-variant rounded-lg flex items-center justify-center hover:bg-surface-container-high transition-colors">
            <span class="material-symbols-outlined text-primary">add</span>
            </button>
            <button class="w-10 h-10 glass-panel border border-outline-variant rounded-lg flex items-center justify-center hover:bg-surface-container-high transition-colors">
            <span class="material-symbols-outlined text-primary">remove</span>
            </button>
            <button class="w-10 h-10 glass-panel border border-outline-variant rounded-lg flex items-center justify-center hover:bg-surface-container-high transition-colors mt-4">
            <span class="material-symbols-outlined text-primary">layers</span>
            </button>
        </div>
        </div>

        <aside class="w-[380px] bg-surface-container-lowest border-l border-outline-variant flex flex-col p-6 overflow-y-auto shrink-0">

        <div class="mb-6">
            <h2 class="text-xl font-semibold text-primary mb-1">Resultados de la Auditoría</h2>
            <p class="text-on-surface-variant text-sm">Análisis en tiempo real del área poligonal seleccionada para el cumplimiento del EUDR.</p>
        </div>

        <div class="bg-surface-container-low border border-outline-variant rounded-xl p-4 mb-4">
            <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-bold text-on-surface">Estado de Validación EUDR</span>
            <div class="flex items-center gap-2 px-3 py-1 bg-secondary/10 border border-secondary/20 rounded-full">
                <span class="w-2 h-2 rounded-full bg-secondary"></span>
                <span class="text-[10px] font-bold text-secondary uppercase tracking-tighter">Aprobado</span>
            </div>
            </div>
            <div class="flex flex-col gap-3">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-primary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-primary-container" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                </div>
                <div>
                <div class="font-bold text-on-surface text-sm">Sin Deforestación Detectada</div>
                <div class="text-xs text-on-surface-variant">Comparación de línea base: 31-12-2020</div>
                </div>
            </div>
            <div class="border-t border-outline-variant pt-3 flex flex-col gap-2">
                <div class="flex justify-between text-sm">
                <span class="text-on-surface-variant">Densidad del Dosel</span>
                <span class="font-bold">89.4%</span>
                </div>
                <div class="w-full bg-outline-variant rounded-full h-1.5 overflow-hidden">
                <div class="bg-primary h-full" style="width: 89.4%"></div>
                </div>
            </div>
            </div>
        </div>

        <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-container mb-6">
            <span class="material-symbols-outlined text-primary-container shrink-0">info</span>
            <p class="text-xs leading-relaxed text-on-surface-variant">
            Auditoría basada en datos del Copernicus Open Access Hub. Precisión geométrica: <span class="font-bold">+/- 5m</span>.
            </p>
        </div>

        <div class="mt-auto space-y-3">
            <button
            id="btn-audit"
            class="w-full py-3 bg-primary text-white rounded-xl font-bold hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-sm group"
            >
            <span class="material-symbols-outlined text-white transition-transform group-hover:rotate-180">refresh</span>
            Ejecutar Auditoría GEE
            </button>
            <button class="w-full py-3 bg-white border border-outline-variant text-primary rounded-xl font-bold hover:bg-surface-container-high active:scale-[0.98] transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined">description</span>
            Generar Certificado DDS
            </button>
        </div>

        </aside>
    </section>

    </Layout>

    <style>
    .scanning-line {
        position: absolute;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, #0d5c3a, transparent);
        box-shadow: 0 0 15px #8ed6aa;
        animation: scan 4s linear infinite;
        z-index: 20;
    }
    @keyframes scan {
        0%   { top: 0%;   opacity: 0; }
        10%  { opacity: 1; }
        90%  { opacity: 1; }
        100% { top: 100%; opacity: 0; }
    }
    .glass-panel {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }
    .map-gradient-overlay {
        background: radial-gradient(circle at center, transparent 30%, rgba(0, 67, 40, 0.1) 100%);
    }
    </style>

    <script>
    const btnAudit = document.getElementById("btn-audit") as HTMLButtonElement;
    const scanningLine = document.querySelector(".scanning-line") as HTMLElement;

    btnAudit?.addEventListener("click", () => {
        btnAudit.disabled = true;
        btnAudit.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Ejecutando Análisis...';
        scanningLine.style.animationDuration = "1.5s";

        setTimeout(() => {
        btnAudit.disabled = false;
        btnAudit.innerHTML = '<span class="material-symbols-outlined text-white">refresh</span> Ejecutar Auditoría GEE';
        scanningLine.style.animationDuration = "4s";

        const notification = document.createElement("div");
        notification.className = "fixed bottom-6 right-6 bg-primary text-white px-6 py-3 rounded-lg shadow-xl z-50 text-sm font-semibold";
        notification.innerText = "Auditoría Satelital Completada con Éxito";
        document.body.appendChild(notification);
        setTimeout(() => notification.remove(), 3000);
        }, 3000);
    });
    </script>
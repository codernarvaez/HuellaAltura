---
import Layout from "../layouts/Layout.astro";
import { createServerSupabase } from "../lib/supabase/server";

export const prerender = false;

const configured = Boolean(
  import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;

if (configured) {
  const supabase = createServerSupabase(Astro.cookies);
  const {
    data: { user },
  } = await supabase.auth.getUser();

  if (user) {
    return Astro.redirect("/dashboard");
  }
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Acceso a la Plataforma — Huella de Altura">
  <header class="border-b border-outline-variant/50 bg-white/90 backdrop-blur-xl">
    <nav class="max-w-container-max mx-auto px-6 flex justify-between items-center h-20">
      <a class="text-headline-md font-display tracking-tighter text-primary flex items-center" href="/">
        <span class="material-symbols-outlined mr-2 text-primary" style="font-variation-settings: 'FILL' 1;">landscape</span>
        Huella de Altura
      </a>
      <a class="text-on-surface-variant font-label-md text-label-md hover:text-secondary transition-colors" href="/">
        Volver al inicio
      </a>
    </nav>
  </header>

  <main class="min-h-[calc(100vh-5rem)] bg-surface-container-low flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <span class="inline-block px-4 py-1 bg-secondary-container text-on-secondary-container text-label-sm font-label-sm rounded-full mb-4">
          Plataforma Agrotech
        </span>
        <h1 class="font-headline-lg text-headline-lg text-primary">Acceso a la Plataforma</h1>
        <p class="text-on-surface-variant mt-2">
          Regístrate o inicia sesión para digitalizar y certificar tu producción.
        </p>
      </div>

      {!configured && (
        <div class="mb-6 rounded-xl border border-secondary/30 bg-secondary-container/30 px-4 py-3 text-sm text-on-secondary-container">
          Configura Supabase en <code class="font-mono">HAFront/.env</code> (copia desde <code class="font-mono">.env.example</code>) para activar Google, email y MetaMask.
        </div>
      )}

      {error === "supabase" && (
        <div class="mb-6 rounded-xl border border-error/30 bg-error-container px-4 py-3 text-sm text-on-error-container">
          Supabase no está configurado. Revisa las variables de entorno.
        </div>
      )}

      <div id="auth-alert" class="hidden mb-6 rounded-xl border px-4 py-3 text-sm" role="alert"></div>

      <div class="bg-white border border-outline-variant rounded-2xl shadow-xl p-8 space-y-6">
        <div class="grid grid-cols-2 gap-2 p-1 bg-surface-container rounded-xl">
          <button
            type="button"
            id="tab-register"
            class="auth-tab rounded-lg px-4 py-2 font-label-md text-label-md transition-all bg-primary text-on-primary"
          >
            Registrarse
          </button>
          <button
            type="button"
            id="tab-login"
            class="auth-tab rounded-lg px-4 py-2 font-label-md text-label-md transition-all text-on-surface-variant hover:text-primary"
          >
            Iniciar sesión
          </button>
        </div>

        <div class="space-y-3">
          <button
            type="button"
            id="btn-google"
            class="w-full flex items-center justify-center gap-3 border border-outline-variant rounded-xl px-4 py-3 font-label-md text-label-md hover:bg-surface-container-low transition-all disabled:opacity-50"
            disabled={!configured}
          >
            <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"></path>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
            </svg>
            Continuar con Google
          </button>

          <button
            type="button"
            id="btn-metamask"
            class="w-full flex items-center justify-center gap-3 border border-outline-variant rounded-xl px-4 py-3 font-label-md text-label-md hover:bg-surface-container-low transition-all disabled:opacity-50"
            disabled={!configured}
          >
            <span class="material-symbols-outlined text-secondary">account_balance_wallet</span>
            Continuar con MetaMask
          </button>
        </div>

        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-outline-variant/50"></div>
          </div>
          <div class="relative flex justify-center">
            <span class="bg-white px-3 text-label-sm text-on-surface-variant">o con email</span>
          </div>
        </div>

        <form id="auth-form" class="space-y-4">
          <div id="field-name" class="space-y-2">
            <label class="block text-label-md font-label-md text-primary" for="full-name">Nombre completo</label>
            <input
              id="full-name"
              name="fullName"
              type="text"
              autocomplete="name"
              class="w-full bg-surface-container-low border border-outline-variant px-4 py-3 rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary outline-none"
              placeholder="Ej. Juan Pérez"
            />
          </div>

          <div class="space-y-2">
            <label class="block text-label-md font-label-md text-primary" for="email">Correo electrónico</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full bg-surface-container-low border border-outline-variant px-4 py-3 rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary outline-none"
              placeholder="tu@empresa.com"
            />
          </div>

          <div class="space-y-2">
            <label class="block text-label-md font-label-md text-primary" for="password">Contraseña</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              minlength="8"
              autocomplete="current-password"
              class="w-full bg-surface-container-low border border-outline-variant px-4 py-3 rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary outline-none"
              placeholder="Mínimo 8 caracteres"
            />
          </div>

          <button
            type="submit"
            id="btn-email"
            class="w-full bg-primary text-on-primary px-6 py-3 rounded-xl font-label-md text-label-md hover:bg-primary-container transition-all shadow-sm disabled:opacity-50"
            disabled={!configured}
          >
            Crear cuenta
          </button>
        </form>

        <p class="text-center text-label-sm text-on-surface-variant">
          Al continuar aceptas nuestros
          <a class="text-secondary underline hover:text-primary" href="/legal/terminos">Términos de Uso</a>,
          la <a class="text-secondary underline hover:text-primary" href="/legal/privacidad">Política de Privacidad</a>
          y la <a class="text-secondary underline hover:text-primary" href="/legal/cookies">Política de Cookies</a>.
        </p>
      </div>
    </div>
  </main>

  <script define:vars={{ configured, siteUrl }}>
    const tabRegister = document.getElementById("tab-register");
    const tabLogin = document.getElementById("tab-login");
    const fieldName = document.getElementById("field-name");
    const authForm = document.getElementById("auth-form");
    const btnEmail = document.getElementById("btn-email");
    const btnGoogle = document.getElementById("btn-google");
    const btnMetamask = document.getElementById("btn-metamask");
    const alertBox = document.getElementById("auth-alert");

    let mode = "register";

    function showAlert(message, type = "error") {
      alertBox.textContent = message;
      alertBox.classList.remove("hidden", "border-error/30", "bg-error-container", "text-on-error-container", "border-primary/30", "bg-primary-fixed", "text-on-primary-fixed-variant");
      if (type === "success") {
        alertBox.classList.add("border-primary/30", "bg-primary-fixed", "text-on-primary-fixed-variant");
      } else {
        alertBox.classList.add("border-error/30", "bg-error-container", "text-on-error-container");
      }
    }

    function setMode(nextMode) {
      mode = nextMode;
      const isRegister = mode === "register";

      tabRegister.classList.toggle("bg-primary", isRegister);
      tabRegister.classList.toggle("text-on-primary", isRegister);
      tabRegister.classList.toggle("text-on-surface-variant", !isRegister);

      tabLogin.classList.toggle("bg-primary", !isRegister);
      tabLogin.classList.toggle("text-on-primary", !isRegister);
      tabLogin.classList.toggle("text-on-surface-variant", isRegister);

      fieldName.classList.toggle("hidden", !isRegister);
      btnEmail.textContent = isRegister ? "Crear cuenta" : "Iniciar sesión";
      document.getElementById("password").autocomplete = isRegister ? "new-password" : "current-password";
    }

    tabRegister?.addEventListener("click", () => setMode("register"));
    tabLogin?.addEventListener("click", () => setMode("login"));

    async function getSupabase() {
      const { createClient } = await import("../lib/supabase/client.ts");
      return createClient();
    }

    btnGoogle?.addEventListener("click", async () => {
      if (!configured) return;

      try {
        const supabase = await getSupabase();
        const { error } = await supabase.auth.signInWithOAuth({
          provider: "google",
          options: {
            redirectTo: `${siteUrl}/auth/callback`,
          },
        });

        if (error) showAlert(error.message);
      } catch (error) {
        showAlert(error instanceof Error ? error.message : "Error con Google Auth.");
      }
    });

    btnMetamask?.addEventListener("click", async () => {
      if (!configured) return;

      const ethereum = window.ethereum;
      if (!ethereum) {
        showAlert("MetaMask no está instalado. Instálalo desde metamask.io");
        return;
      }

      try {
        btnMetamask.disabled = true;
        btnMetamask.textContent = "Conectando wallet…";

        const [address] = await ethereum.request({ method: "eth_requestAccounts" });
        const nonceRes = await fetch("/api/auth/nonce");
        const { nonce } = await nonceRes.json();

        const message = [
          "Huella de Altura quiere que inicies sesión con tu wallet.",
          "",
          `Dirección: ${address}`,
          `Nonce: ${nonce}`,
        ].join("\n");

        const signature = await ethereum.request({
          method: "personal_sign",
          params: [message, address],
        });

        const verifyRes = await fetch("/api/auth/wallet", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ address, message, signature }),
          redirect: "follow",
        });

        if (verifyRes.redirected) {
          window.location.href = verifyRes.url;
          return;
        }

        const payload = await verifyRes.json().catch(() => ({}));
        if (!verifyRes.ok) {
          showAlert(payload.error ?? "No se pudo autenticar con MetaMask.");
          return;
        }

        window.location.href = "/dashboard";
      } catch (error) {
        showAlert(error instanceof Error ? error.message : "Error al conectar MetaMask.");
      } finally {
        btnMetamask.disabled = false;
        btnMetamask.innerHTML = '<span class="material-symbols-outlined text-secondary">account_balance_wallet</span> Continuar con MetaMask';
      }
    });

    authForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!configured) return;

      const formData = new FormData(authForm);
      const email = String(formData.get("email") ?? "");
      const password = String(formData.get("password") ?? "");
      const fullName = String(formData.get("fullName") ?? "");

      try {
        btnEmail.disabled = true;
        const supabase = await getSupabase();

        if (mode === "register") {
          const { error } = await supabase.auth.signUp({
            email,
            password,
            options: {
              data: { full_name: fullName, auth_provider: "email" },
              emailRedirectTo: `${siteUrl}/auth/callback`,
            },
          });

          if (error) {
            showAlert(error.message);
            return;
          }

          showAlert("Revisa tu correo para confirmar la cuenta.", "success");
          return;
        }

        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) {
          showAlert(error.message);
          return;
        }

        window.location.href = "/dashboard";
      } catch (error) {
        showAlert(error instanceof Error ? error.message : "Error de autenticación.");
      } finally {
        btnEmail.disabled = false;
      }
    });
  </script>
</Layout>

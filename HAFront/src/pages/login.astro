---
import Layout from "../layouts/Layout.astro";
import { createServerSupabase } from "../lib/supabase/server";

export const prerender = false;

const configured = Boolean(
  import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;

if (configured) {
  const supabase = createServerSupabase(Astro.cookies);
  const { data: { user } } = await supabase.auth.getUser();
  if (user) return Astro.redirect("/dashboard");
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Huella de Altura - Acceso a la Plataforma">
  <main class="min-h-screen flex flex-col md:flex-row overflow-hidden">

    <!-- Lado izquierdo: Formulario -->
    <section class="w-full md:w-1/2 lg:w-[45%] flex flex-col justify-center items-center p-8 md:p-12 lg:p-16 bg-surface z-10">

      <!-- Botón volver -->
      <div class="w-full max-w-md mb-6">
        <a href="/" class="flex items-center gap-1 text-on-surface-variant hover:text-primary font-label-md text-label-md transition-colors">
          <span class="material-symbols-outlined text-xl">arrow_back</span>
          Volver al inicio
        </a>
      </div>

      <div class="max-w-md w-full space-y-8">

        <!-- Brand -->
        <div class="flex flex-col items-start space-y-3">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">landscape</span>
            <h1 class="text-primary font-headline-md text-headline-md font-bold tracking-tight">Huella de Altura</h1>
          </div>
          <div class="space-y-1">
            <h2 class="text-on-surface font-headline-lg text-headline-lg-mobile md:text-headline-lg">Acceso a la Plataforma</h2>
            <p class="text-on-surface-variant font-body-md text-body-md">Regístrate o inicia sesión para digitalizar y certificar tu producción.</p>
          </div>
        </div>

        <!-- Alertas -->
        {!configured && (
          <div class="rounded-xl border border-secondary/30 bg-secondary-container/30 px-4 py-3 text-sm text-on-secondary-container">
            Configura Supabase en <code class="font-mono">HAFront/.env</code> para activar autenticación.
          </div>
        )}
        {error === "supabase" && (
          <div class="rounded-xl border border-error/30 bg-error-container px-4 py-3 text-sm text-on-error-container">
            Supabase no está configurado. Revisa las variables de entorno.
          </div>
        )}
        <div id="auth-alert" class="hidden rounded-xl border px-4 py-3 text-sm" role="alert"></div>

        <!-- Card principal -->
        <div class="bg-white border border-outline-variant rounded-2xl shadow-sm p-8 space-y-6">

          <!-- Tabs -->
          <div class="grid grid-cols-2 gap-2 p-1 bg-surface-container rounded-xl">
            <button type="button" id="tab-register"
              class="auth-tab rounded-lg px-4 py-2 font-label-md text-label-md transition-all bg-primary text-on-primary">
              Registrarse
            </button>
            <button type="button" id="tab-login"
              class="auth-tab rounded-lg px-4 py-2 font-label-md text-label-md transition-all text-on-surface-variant hover:text-primary">
              Iniciar sesión
            </button>
          </div>

          <!-- Social login -->
          <div class="space-y-3">
            <button type="button" id="btn-google"
              class="w-full flex items-center justify-center gap-3 border border-outline-variant rounded-xl px-4 py-3 font-label-md text-label-md hover:bg-surface-container-low transition-all disabled:opacity-50"
              disabled={!configured}>
              <svg class="h-5 w-5" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              Continuar con Google
            </button>

            <button type="button" id="btn-metamask"
              class="w-full flex items-center justify-center gap-3 border border-outline-variant rounded-xl px-4 py-3 font-label-md text-label-md hover:bg-surface-container-low transition-all disabled:opacity-50"
              disabled={!configured}>
              <span class="material-symbols-outlined text-secondary">account_balance_wallet</span>
              Continuar con MetaMask
            </button>
          </div>

          <!-- Divider -->
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-outline-variant/50"></div>
            </div>
            <div class="relative flex justify-center">
              <span class="bg-white px-3 text-label-sm text-on-surface-variant">o con email</span>
            </div>
          </div>

          <!-- Form email -->
          <form id="auth-form" class="space-y-4">

            <div id="field-name" class="group">
              <label class="block text-on-surface font-label-md text-label-md mb-2" for="full-name">Nombre completo</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-on-surface-variant group-focus-within:text-primary transition-colors">
                  <span class="material-symbols-outlined text-xl">person</span>
                </span>
                <input id="full-name" name="fullName" type="text" autocomplete="name"
                  class="w-full pl-11 pr-4 py-3 bg-white border border-outline-variant rounded-xl text-on-surface font-body-md focus:outline-none focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all placeholder:text-outline/50"
                  placeholder="Ej. Juan Pérez" />
              </div>
            </div>

            <div class="group">
              <label class="block text-on-surface font-label-md text-label-md mb-2" for="email">Correo electrónico</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-on-surface-variant group-focus-within:text-primary transition-colors">
                  <span class="material-symbols-outlined text-xl">alternate_email</span>
                </span>
                <input id="email" name="email" type="email" required autocomplete="email"
                  class="w-full pl-11 pr-4 py-3 bg-white border border-outline-variant rounded-xl text-on-surface font-body-md focus:outline-none focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all placeholder:text-outline/50"
                  placeholder="tu@empresa.com" />
              </div>
            </div>

            <div class="group">
              <div class="flex justify-between items-center mb-2">
                <label class="block text-on-surface font-label-md text-label-md" for="password">Contraseña</label>
                <a class="text-primary font-label-sm text-label-sm hover:underline transition-all" href="#">¿Olvidaste tu contraseña?</a>
              </div>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-on-surface-variant group-focus-within:text-primary transition-colors">
                  <span class="material-symbols-outlined text-xl">lock</span>
                </span>
                <input id="password" name="password" type="password" required minlength="8" autocomplete="current-password"
                  class="w-full pl-11 pr-12 py-3 bg-white border border-outline-variant rounded-xl text-on-surface font-body-md focus:outline-none focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all placeholder:text-outline/50"
                  placeholder="Mínimo 8 caracteres" />
                <button class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant hover:text-primary transition-colors" id="toggle-password" type="button">
                  <span class="material-symbols-outlined text-xl">visibility</span>
                </button>
              </div>
            </div>

            <button type="submit" id="btn-email"
              class="w-full py-4 bg-primary hover:bg-primary-container text-on-primary font-label-md text-label-md rounded-xl transition-all flex items-center justify-center gap-2 group active:scale-[0.98] disabled:opacity-50"
              disabled={!configured}>
              <span>Crear cuenta</span>
              <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </button>
          </form>

          <p class="text-center text-label-sm text-on-surface-variant">
            Al continuar aceptas nuestros
            <a class="text-secondary underline hover:text-primary" href="/legal/terminos">Términos</a>,
            <a class="text-secondary underline hover:text-primary" href="/legal/privacidad">Privacidad</a>
            y <a class="text-secondary underline hover:text-primary" href="/legal/cookies">Cookies</a>.
          </p>
        </div>

      </div>
    </section>

    <!-- Lado derecho: Imagen -->
    <section class="hidden md:flex w-full md:w-1/2 lg:w-[55%] relative bg-primary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-tr from-primary/80 via-primary/40 to-transparent z-10"></div>
      <img
        alt="Plantación de Café en Loja, Ecuador"
        class="absolute inset-0 w-full h-full object-cover"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuC0Aoj_j1gLp3-oRygOI9muK3O0zvFTXqIxAJ6AOXVqx81U8a4l66TO5M-3n9hxr0mdEVY0P_eJ2XFyaiY_Gy2c-ig9qlpktWGmth0w4cE_2-3MonZovNhBN8Uohkdup9vNQasrUUFLS3hypzUxhQicOIpuR8HTi19f3cy3NCoVOCstIQU60dxutLq-wttsQk6QxTZRu4KG0xAlB7rBuzPk2y7bdL7qKw_fUNdNTITSrsDmQV9G5vg7mX2opK_5mL9s1BXF3d4FDT5g"
        id="hero-img"
      />

      <!-- Badge altitud -->
      <div class="absolute top-10 right-10 z-20">
        <div class="bg-white/10 backdrop-blur-md p-4 rounded-2xl border border-white/10 flex flex-col items-end gap-1">
          <span class="text-white font-headline-md text-headline-md font-bold">2,450m</span>
          <span class="text-white/70 font-label-sm text-label-sm">Altitud Promedio</span>
        </div>
      </div>

      <!-- Quote -->
      <div class="absolute bottom-16 left-0 p-12 lg:p-16 z-20 max-w-xl text-white">
        <div class="space-y-6">
          <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md">
            <span class="flex h-2 w-2 rounded-full bg-secondary-fixed"></span>
            <span class="text-white font-label-sm text-label-sm">Certificación EUDR Activa</span>
          </div>
          <blockquote class="space-y-4">
            <p class="text-headline-lg font-headline-lg leading-tight italic">
              "Trazabilidad desde el origen para un futuro sostenible y responsable en las montañas de Ecuador."
            </p>
            <footer class="flex items-center gap-4">
              <div>
                <p class="font-label-md font-bold">Carlos Mendoza</p>
                <p class="text-label-sm opacity-80">Director de Sostenibilidad, Loja</p>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script define:vars={{ configured, siteUrl }}>
  // Toggle password
  const toggle = document.getElementById("toggle-password");
  const passwordInput = document.getElementById("password");
  toggle?.addEventListener("click", () => {
    const isPassword = passwordInput.type === "password";
    passwordInput.type = isPassword ? "text" : "password";
    toggle.querySelector("span").textContent = isPassword ? "visibility_off" : "visibility";
  });

  // Tabs
  const tabRegister = document.getElementById("tab-register");
  const tabLogin = document.getElementById("tab-login");
  const fieldName = document.getElementById("field-name");
  const btnEmail = document.getElementById("btn-email");
  const authForm = document.getElementById("auth-form");
  const alertBox = document.getElementById("auth-alert");

  let mode = "register";

  function showAlert(message, type = "error") {
    alertBox.textContent = message;
    alertBox.classList.remove("hidden", "border-error/30", "bg-error-container", "text-on-error-container", "border-primary/30", "bg-primary-fixed", "text-on-primary-fixed-variant");
    if (type === "success") {
      alertBox.classList.add("border-primary/30", "bg-primary-fixed", "text-on-primary-fixed-variant");
    } else {
      alertBox.classList.add("border-error/30", "bg-error-container", "text-on-error-container");
    }
  }

  function setMode(nextMode) {
    mode = nextMode;
    const isRegister = mode === "register";
    tabRegister.classList.toggle("bg-primary", isRegister);
    tabRegister.classList.toggle("text-on-primary", isRegister);
    tabRegister.classList.toggle("text-on-surface-variant", !isRegister);
    tabLogin.classList.toggle("bg-primary", !isRegister);
    tabLogin.classList.toggle("text-on-primary", !isRegister);
    tabLogin.classList.toggle("text-on-surface-variant", isRegister);
    fieldName.classList.toggle("hidden", !isRegister);
    const span = btnEmail.querySelector("span");
    if (span) span.textContent = isRegister ? "Crear cuenta" : "Iniciar sesión";
    passwordInput.autocomplete = isRegister ? "new-password" : "current-password";
  }

  tabRegister?.addEventListener("click", () => setMode("register"));
  tabLogin?.addEventListener("click", () => setMode("login"));

  async function getSupabase() {
    const { createClient } = await import("../lib/supabase/client.ts");
    return createClient();
  }

  document.getElementById("btn-google")?.addEventListener("click", async () => {
    if (!configured) return;
    try {
      const supabase = await getSupabase();
      const { error } = await supabase.auth.signInWithOAuth({
        provider: "google",
        options: { redirectTo: `${siteUrl}/auth/callback` },
      });
      if (error) showAlert(error.message);
    } catch (e) {
      showAlert(e instanceof Error ? e.message : "Error con Google Auth.");
    }
  });

  document.getElementById("btn-metamask")?.addEventListener("click", async () => {
    if (!configured) return;
    const ethereum = window.ethereum;
    if (!ethereum) { showAlert("MetaMask no está instalado."); return; }
    const btn = document.getElementById("btn-metamask");
    try {
      btn.disabled = true;
      btn.textContent = "Conectando wallet…";
      const [address] = await ethereum.request({ method: "eth_requestAccounts" });
      const { nonce } = await (await fetch("/api/auth/nonce")).json();
      const message = `Huella de Altura quiere que inicies sesión.\n\nDirección: ${address}\nNonce: ${nonce}`;
      const signature = await ethereum.request({ method: "personal_sign", params: [message, address] });
      const res = await fetch("/api/auth/wallet", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ address, message, signature }),
        redirect: "follow",
      });
      if (res.redirected) { window.location.href = res.url; return; }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) { showAlert(payload.error ?? "No se pudo autenticar con MetaMask."); return; }
      window.location.href = "/dashboard";
    } catch (e) {
      showAlert(e instanceof Error ? e.message : "Error al conectar MetaMask.");
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined text-secondary">account_balance_wallet</span> Continuar con MetaMask';
    }
  });

  authForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!configured) return;
    const formData = new FormData(authForm);
    const email = String(formData.get("email") ?? "");
    const password = String(formData.get("password") ?? "");
    const fullName = String(formData.get("fullName") ?? "");
    try {
      btnEmail.disabled = true;
      const supabase = await getSupabase();
      if (mode === "register") {
        const { error } = await supabase.auth.signUp({
          email, password,
          options: { data: { full_name: fullName }, emailRedirectTo: `${siteUrl}/auth/callback` },
        });
        if (error) { showAlert(error.message); return; }
        showAlert("Revisa tu correo para confirmar la cuenta.", "success");
        return;
      }
      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) { showAlert(error.message); return; }
      window.location.href = "/dashboard";
    } catch (e) {
      showAlert(e instanceof Error ? e.message : "Error de autenticación.");
    } finally {
      btnEmail.disabled = false;
    }
  });

  // Parallax
  window.addEventListener("mousemove", (e) => {
    const moveX = (e.clientX - window.innerWidth / 2) * 0.01;
    const moveY = (e.clientY - window.innerHeight / 2) * 0.01;
    const img = document.getElementById("hero-img");
    if (img) img.style.transform = `translate(${moveX}px, ${moveY}px) scale(1.05)`;
  });
</script>
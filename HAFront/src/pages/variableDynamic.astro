---
import DashboardLayout from "../layouts/LayoutVariable.astro";
---

<DashboardLayout title="Management Dashboard">

  <div class="space-y-6">

    <!-- HEADER -->
    <section>
      <h1 class="text-3xl font-bold text-primary">
        Dynamic Asset Management
      </h1>

      <p class="text-on-surface-variant mt-2 max-w-2xl">
        Configure your schema and manage environmental records with precision and compliance tracking.
      </p>
    </section>

    <!-- GRID PRINCIPAL -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">

      <!-- FORMULARIO -->
      <div
        class="lg:col-span-4 bg-surface-container-low border border-outline-variant rounded-xl p-6 shadow-sm"
      >

        <div class="flex items-center gap-2 mb-5">
          <span class="material-symbols-outlined text-primary">
            add_circle
          </span>

          <h2 class="font-semibold text-lg">
            Crear Nueva Variable
          </h2>
        </div>

        <form class="space-y-5">

          <!-- Nombre -->
          <div>
            <label class="block text-sm font-medium mb-2">
              Nombre / Etiqueta de la Variable
            </label>

            <input
              type="text"
              placeholder="Ej. pH del Suelo"
              class="w-full h-12 px-4 rounded-xl border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-primary"
            />
          </div>

          <!-- Sección -->
          <div>
            <label class="block text-sm font-medium mb-2">
              Sección de Destino
            </label>

            <select
              class="w-full h-12 px-4 rounded-xl border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-primary"
            >
              <option>Módulo de Biodiversidad</option>
              <option>Módulo de Carbono</option>
              <option>Módulo de Recursos Hídricos</option>
              <option>Módulo de Suelos</option>
            </select>
          </div>

          <!-- Tipo -->
          <div>
            <label class="block text-sm font-medium mb-2">
              Tipo de Dato
            </label>

            <select
              class="w-full h-12 px-4 rounded-xl border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-primary"
            >
              <option>Numérico (Decimal/Entero)</option>
              <option>Texto</option>
              <option>Booleano (Sí / No)</option>
              <option>Fecha</option>
              <option>Porcentaje (%)</option>
            </select>
          </div>

          <!-- Valor por defecto -->
          <div>
            <label class="block text-sm font-medium mb-2">
              Valor por Defecto
            </label>

            <input
              type="text"
              placeholder="Opcional"
              class="w-full h-12 px-4 rounded-xl border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-primary"
            />
          </div>

          <button
            type="submit"
            class="w-full h-12 bg-primary text-white rounded-xl font-medium hover:opacity-90 transition"
          >
            Crear Variable
          </button>

        </form>

      </div>

      <!-- TABLA DE VARIABLES -->
<div
  class="lg:col-span-8 bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm"
>

  <!-- HEADER TABLA -->
  <div class="p-5 border-b border-outline-variant flex justify-between items-center bg-surface-container">

    <h2 class="font-semibold text-lg">
      Variables Activas
    </h2>

    <span
      class="text-xs px-3 py-1 rounded-full bg-secondary-container text-secondary font-medium"
    >
      8 Variables
    </span>

  </div>

  <!-- TABLA -->
  <div class="overflow-x-auto">

    <table class="w-full">

      <thead
        class="bg-surface-container text-on-surface-variant uppercase tracking-wider text-xs"
      >
        <tr>

          <th class="px-5 py-4 text-left font-semibold">
            Variable
          </th>

          <th class="px-5 py-4 text-left font-semibold">
            Módulo
          </th>

          <th class="px-5 py-4 text-left font-semibold">
            Tipo
          </th>

          <th class="px-5 py-4 text-right font-semibold">
            Acciones
          </th>

        </tr>
      </thead>

      <tbody class="divide-y divide-outline-variant text-sm">

        <tr class="bg-white hover:bg-surface-container-low transition-colors">

          <td class="px-5 py-5 font-medium text-on-surface">
            Conteo de Especies Nativas
          </td>

          <td class="px-5 py-5 text-on-surface">
            Biodiversidad
          </td>

          <td class="px-5 py-5 text-on-surface">
            Integer
          </td>

          <td class="px-5 py-5 text-right">
            <button class="text-primary font-medium hover:underline">
              Editar
            </button>
          </td>

        </tr>

        <tr class="bg-white hover:bg-surface-container-low transition-colors">

          <td class="px-5 py-5 font-medium text-on-surface">
            Tasa de Captura de CO₂
          </td>

          <td class="px-5 py-5 text-on-surface">
            Carbono
          </td>

          <td class="px-5 py-5 text-on-surface">
            Decimal
          </td>

          <td class="px-5 py-5 text-right">
            <button class="text-primary font-medium hover:underline">
              Editar
            </button>
          </td>

        </tr>

        <tr class="bg-white hover:bg-surface-container-low transition-colors">

          <td class="px-5 py-5 font-medium text-on-surface">
            Ancho de Franja Ribereña
          </td>

          <td class="px-5 py-5 text-on-surface">
            Recursos Hídricos
          </td>

          <td class="px-5 py-5 text-on-surface">
            Porcentaje
          </td>

          <td class="px-5 py-5 text-right">
            <button class="text-primary font-medium hover:underline">
              Editar
            </button>
          </td>

        </tr>

        <tr class="bg-white hover:bg-surface-container-low transition-colors">

          <td class="px-5 py-5 font-medium text-on-surface">
            pH del Suelo
          </td>

          <td class="px-5 py-5 text-on-surface">
            Suelos
          </td>

          <td class="px-5 py-5 text-on-surface">
            Decimal
          </td>

          <td class="px-5 py-5 text-right">
            <button class="text-primary font-medium hover:underline">
              Editar
            </button>
          </td>

        </tr>

      </tbody>

    </table>

  </div>

</div>

    </div>

  </div>

</DashboardLayout>
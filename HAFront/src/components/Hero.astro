<section class="py-section-py-desktop max-w-container-max mx-auto px-6" id="inicio">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <div class="space-y-6">
      <span class="inline-block px-4 py-1 bg-secondary-container text-on-secondary-container text-label-sm font-label-sm rounded-full">
        Agrotech &amp; Blockchain
      </span>
      <h1 class="font-display text-display text-primary tracking-tighter">
        Huella de Altura: Trazabilidad Blockchain para la certificación global de su producción.
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl">
        Lideramos la transformación del sector agroindustrial con soluciones tecnológicas que garantizan transparencia, origen y calidad superior en mercados internacionales.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <button class="bg-primary text-on-primary px-8 py-4 rounded-xl font-label-md text-label-md hover:bg-primary-container transition-all shadow-md">
          Digitalizar mi Producción
        </button>
        <button class="border border-outline text-primary px-8 py-4 rounded-xl font-label-md text-label-md hover:bg-surface-container-low transition-all">
          Explorar Certificaciones
        </button>
      </div>
    </div>
    <div class="relative group perspective-lg">

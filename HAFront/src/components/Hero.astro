            <span class="text-primary font-bold">VERIFICADO</span>
          </div>
          <div class="flex items-center justify-between p-4 bg-surface-container-low rounded-xl border border-outline-variant/30">
            <span class="text-label-md font-label-md text-on-surface-variant uppercase">Huella de Carbono</span>
            <span class="text-secondary font-bold">ÓPTIMA</span>

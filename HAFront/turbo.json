{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tags": ["frontend", "web"],
  "tasks": {
    "build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_EXTENDS$",
        "astro.config.mjs",
        "tsconfig.json",
        "src/**",
        "public/**"
      ],
      "outputs": [
        "$TURBO_EXTENDS$",
        "dist/**",
        ".astro/**"
      ],
      "env": [
        "PUBLIC_SUPABASE_URL",
        "PUBLIC_SUPABASE_ANON_KEY",
        "PUBLIC_SITE_URL"
      ]
    },
    "check": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_EXTENDS$",
        "astro.config.mjs",
        "tsconfig.json",
        "src/**"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["$TURBO_EXTENDS$", "src/**"],
      "outputs": []
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  }
}

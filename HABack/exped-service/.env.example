# Base de datos PostgreSQL (Neon u otro proveedor)
DATABASE_URL="postgresql://usuario:password@host/neondb?sslmode=require"

# JWT — misma SECRET_KEY que auth-service (HS256, obligatorio que coincidan)
SECRET_KEY="tu_clave_secreta_aqui"

# Comunicación interna S2S — misma clave que auth-service (obligatorio que coincidan)
INTERNAL_API_KEY="tu_api_key_interna_aqui"

# URL del auth-service (local o producción)
AUTH_SERVICE_URL=http://localhost:8000

# Validación de session_token contra auth-service (desactivar solo en tests locales)
SESSION_VALIDATION_ENABLED=true
